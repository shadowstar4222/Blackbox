<Window x:Class="Blackbox.App.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostics - Blackbox"
        Height="700"
        Width="980"
        MinHeight="580"
        MinWidth="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Diagnostics" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Recovery health and recent Blackbox activity"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="ExportSupportBundleButton"
                        Content="Support bundle"
                        MinWidth="110"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="ExportSupportBundleButton_Click" />
                <Button x:Name="OpenLogsButton"
                        Content="Open logs"
                        MinWidth="90"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="OpenLogsButton_Click" />
                <Button x:Name="OpenBackupsButton"
                        Content="Recovery backups"
                        MinWidth="125"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="OpenBackupsButton_Click" />
                <Button x:Name="RefreshButton"
                        Content="Refresh"
                        MinWidth="85"
                        Height="32"
                        Click="RefreshButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Recording" FontWeight="SemiBold" />
            <TextBlock x:Name="RecordingStatusText" Grid.Column="1" />
            <TextBlock Grid.Column="2" Text="Automatic capture" FontWeight="SemiBold" />
            <TextBlock x:Name="AutomaticStatusText" Grid.Column="3" />

            <TextBlock Grid.Row="1" Text="Indexed media" FontWeight="SemiBold" Margin="0,9,0,0" />
            <TextBlock x:Name="IndexedMediaText" Grid.Row="1" Grid.Column="1" Margin="0,9,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Recording storage" FontWeight="SemiBold" Margin="0,9,0,0" />
            <TextBlock x:Name="RecordingStorageText" Grid.Row="1" Grid.Column="3" Margin="0,9,0,0" />

            <TextBlock Grid.Row="2" Text="Last recovery" FontWeight="SemiBold" Margin="0,9,0,0" />
            <TextBlock x:Name="RecoverySummaryText"
                       Grid.Row="2"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Margin="0,9,0,0"
                       TextWrapping="Wrap" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Recent events" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ComboBox x:Name="CategoryComboBox"
                      Grid.Column="1"
                      Width="150"
                      Height="30"
                      SelectionChanged="CategoryComboBox_SelectionChanged" />
        </Grid>

        <ListBox x:Name="LogListBox"
                 Grid.Row="3"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145" />
                            <ColumnDefinition Width="185" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        <TextBlock Grid.Column="1"
                                   Margin="0,0,12,0"
                                   Text="{Binding CategoryAndSeverity}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CategoryAndSeverity}" />
                        <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Margin="0,10,0,0"
                   Text="Loading diagnostics..."
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
    </Grid>
</Window>
