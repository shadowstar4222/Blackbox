<Window x:Class="Blackbox.App.RecordingLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Blackbox.App"
        Title="Timeline - Blackbox"
        Height="820"
        Width="1180"
        MinHeight="700"
        MinWidth="1000"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Recording timeline" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="Loading recording sessions..."
                           TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="OpenFolderButton"
                        Content="Open folder"
                        MinWidth="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="OpenFolderButton_Click" />
                <Button x:Name="RefreshButton"
                        Content="Refresh"
                        MinWidth="90"
                        Height="32"
                        Click="RefreshButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SessionListBox"
                     BorderThickness="1"
                     SelectionChanged="SessionListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8" Width="232">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,4,0,0"
                                       Text="{Binding RecordedAt}"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,3,0,0"
                                       Text="{Binding Summary}"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator Grid.Column="1" Margin="11,0" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="SessionTitleText"
                                   Text="Select a recording"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SessionSummaryText"
                                   Margin="0,4,0,0"
                                   Text="-"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock x:Name="HealthText"
                               Grid.Column="1"
                               Margin="20,0,0,0"
                               FontWeight="SemiBold"
                               Text="-"
                               VerticalAlignment="Center" />
                </Grid>

                <TabControl Grid.Row="1" Margin="0,14,0,0">
                    <TabItem Header="Timeline">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="180" />
                                <RowDefinition Height="112" />
                                <RowDefinition Height="92" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#1E1E1E" BorderBrush="#555555" BorderThickness="1">
                                    <Image x:Name="PreviewImage"
                                           Width="318"
                                           Height="178"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True" />
                                </Border>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="CursorTimeText" Text="0:00" FontSize="26" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                        <TextBlock x:Name="PreviewStatusText"
                                                   Text="Timeline preview pending"
                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                   TextWrapping="Wrap" />
                                        <Button x:Name="BuildPreviewButton"
                                                Content="Build preview"
                                                MinWidth="104"
                                                Height="28"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Left"
                                                Visibility="Collapsed"
                                                Click="BuildPreviewButton_Click" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Rectangle Width="18" Height="10" Fill="#733A8B5A" Margin="0,0,8,0" />
                                            <TextBlock Text="Protected" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Rectangle Width="18" Height="10" Fill="#96B64D4D" Margin="0,0,8,0" />
                                            <TextBlock Text="Damaged" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="2" Height="12" Fill="#F4C95D" Margin="8,0,16,0" />
                                            <TextBlock Text="Marker" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock x:Name="HealthDetailText"
                                               Grid.Row="3"
                                               Margin="0,16,0,0"
                                               Text="-"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                </Grid>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ThumbnailItemsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="162" Margin="0,0,6,0">
                                                <Border Width="160" Height="90" Background="#1E1E1E" BorderBrush="#555555" BorderThickness="1">
                                                    <Image Source="{Binding Image}" Stretch="Uniform" />
                                                </Border>
                                                <TextBlock Text="{Binding Time}" Margin="0,3,0,0" FontSize="11" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <local:TimelineWaveformControl x:Name="WaveformTimeline"
                                                           Grid.Row="2"
                                                           Height="82"
                                                           Margin="0,10,0,0"
                                                           ToolTip="Scrub timeline" />

                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cursor" VerticalAlignment="Center" />
                                <Slider x:Name="PlayheadSlider"
                                        Grid.Column="1"
                                        Margin="0,0,12,0"
                                        Minimum="0"
                                        IsEnabled="False"
                                        ValueChanged="PlayheadSlider_ValueChanged" />
                                <TextBlock x:Name="PlayheadTimeText" Grid.Column="2" Text="0:00" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Start" VerticalAlignment="Center" />
                                <Slider x:Name="SelectionStartSlider"
                                        Grid.Column="1"
                                        Margin="0,0,12,0"
                                        Minimum="0"
                                        IsEnabled="False"
                                        ValueChanged="SelectionStartSlider_ValueChanged" />
                                <TextBlock x:Name="SelectionStartText" Grid.Column="2" Text="0:00" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Text="End" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <Slider x:Name="SelectionEndSlider"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,8,12,0"
                                        Minimum="0"
                                        IsEnabled="False"
                                        ValueChanged="SelectionEndSlider_ValueChanged" />
                                <TextBlock x:Name="SelectionEndText"
                                           Grid.Row="1"
                                           Grid.Column="2"
                                           Margin="0,8,0,0"
                                           Text="0:00"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="5" Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="PlayButton"
                                            Content="Play from cursor"
                                            MinWidth="130"
                                            Height="32"
                                            IsEnabled="False"
                                            Click="PlayButton_Click" />
                                    <Button x:Name="FullSessionButton"
                                            Content="Use full"
                                            MinWidth="90"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            IsEnabled="False"
                                            Click="FullSessionButton_Click" />
                                    <Button x:Name="AddMarkerButton"
                                            Content="Add marker"
                                            MinWidth="100"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            IsEnabled="False"
                                            Click="AddMarkerButton_Click" />
                                    <Button x:Name="ProtectSelectionButton"
                                            Content="Protect selection"
                                            MinWidth="130"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            IsEnabled="False"
                                            Click="ProtectSelectionButton_Click" />
                                </StackPanel>
                                <ListBox x:Name="MarkerListBox"
                                         Grid.Row="1"
                                         Margin="0,10,0,0"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Time}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                                <Button Grid.Column="2"
                                                        Content="Remove"
                                                        MinWidth="70"
                                                        Height="24"
                                                        CommandParameter="{Binding Id}"
                                                        Click="DeleteMarkerButton_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Audio &amp; export">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Preset" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <ComboBox x:Name="ExportPresetComboBox"
                                          Grid.Column="1"
                                          Height="30"
                                          SelectionChanged="ExportPresetComboBox_SelectionChanged" />
                                <TextBlock x:Name="ExportRangeText"
                                           Grid.Column="2"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Selection 0:00 - 0:00"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,18,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="64" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Track" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Mute" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="Solo" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="Volume" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="WAV" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="AudioTrackItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="48">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="58" />
                                                    <ColumnDefinition Width="64" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                <CheckBox Grid.Column="1"
                                                          IsChecked="{Binding IsMuted}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Checked="AudioTrackControl_Changed"
                                                          Unchecked="AudioTrackControl_Changed" />
                                                <CheckBox Grid.Column="2"
                                                          IsChecked="{Binding IsSolo}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Checked="AudioTrackControl_Changed"
                                                          Unchecked="AudioTrackControl_Changed" />
                                                <Slider Grid.Column="3"
                                                        Minimum="0"
                                                        Maximum="2"
                                                        Value="{Binding Volume}"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center"
                                                        ValueChanged="AudioVolumeSlider_ValueChanged" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding VolumeText}"
                                                           VerticalAlignment="Center" />
                                                <CheckBox Grid.Column="5"
                                                          IsChecked="{Binding ExportAsWav}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Checked="AudioTrackControl_Changed"
                                                          Unchecked="AudioTrackControl_Changed" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                                <Button x:Name="ExportButton"
                                        Content="Export selection"
                                        MinWidth="140"
                                        Height="34"
                                        IsEnabled="False"
                                        Click="ExportButton_Click" />
                                <Button x:Name="CancelExportButton"
                                        Content="Cancel"
                                        MinWidth="85"
                                        Height="34"
                                        Margin="10,0,0,0"
                                        Visibility="Collapsed"
                                        Click="CancelExportButton_Click" />
                                <Button x:Name="OpenExportButton"
                                        Content="Open export"
                                        MinWidth="110"
                                        Height="34"
                                        Margin="10,0,0,0"
                                        Visibility="Collapsed"
                                        Click="OpenExportButton_Click" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <ProgressBar x:Name="OperationProgressBar"
                     Grid.Row="2"
                     Height="7"
                     Minimum="0"
                     Maximum="100"
                     Visibility="Collapsed" />
    </Grid>
</Window>
