<Window x:Class="Blackbox.App.RecordingLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recordings - Blackbox"
        Height="660"
        Width="960"
        MinHeight="580"
        MinWidth="820"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Recordings" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="Loading recording sessions..."
                           TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="OpenFolderButton"
                        Content="Open folder"
                        MinWidth="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="OpenFolderButton_Click" />
                <Button x:Name="RefreshButton"
                        Content="Refresh"
                        MinWidth="90"
                        Height="32"
                        Click="RefreshButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SessionListBox"
                     BorderThickness="1"
                     SelectionChanged="SessionListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8" Width="260">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,4,0,0"
                                       Text="{Binding RecordedAt}"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,3,0,0"
                                       Text="{Binding Summary}"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator Grid.Column="1" Margin="11,0" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="SessionTitleText"
                           Text="Select a recording"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recorded" FontWeight="SemiBold" />
                    <TextBlock x:Name="RecordedText" Grid.Column="1" Text="-" />
                    <TextBlock Grid.Row="1" Text="Duration" FontWeight="SemiBold" />
                    <TextBlock x:Name="DurationText" Grid.Row="1" Grid.Column="1" Text="-" />
                    <TextBlock Grid.Row="2" Text="Media" FontWeight="SemiBold" />
                    <TextBlock x:Name="MediaText" Grid.Row="2" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Text="Timeline" FontWeight="SemiBold" />
                    <TextBlock x:Name="HealthText" Grid.Row="3" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                </Grid>

                <Separator Grid.Row="2" Margin="0,14" />

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="78" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Selection" FontWeight="SemiBold" />
                    <Button x:Name="FullSessionButton"
                            Grid.Column="2"
                            Content="Use full"
                            Height="26"
                            IsEnabled="False"
                            Click="FullSessionButton_Click" />

                    <TextBlock Grid.Row="1" Text="Start" Margin="0,14,0,0" VerticalAlignment="Center" />
                    <Slider x:Name="SelectionStartSlider"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,14,12,0"
                            Minimum="0"
                            IsEnabled="False"
                            ValueChanged="SelectionStartSlider_ValueChanged" />
                    <TextBlock x:Name="SelectionStartText"
                               Grid.Row="1"
                               Grid.Column="2"
                               Margin="0,14,0,0"
                               Text="00:00"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="2" Text="End" Margin="0,10,0,0" VerticalAlignment="Center" />
                    <Slider x:Name="SelectionEndSlider"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,10,12,0"
                            Minimum="0"
                            IsEnabled="False"
                            ValueChanged="SelectionEndSlider_ValueChanged" />
                    <TextBlock x:Name="SelectionEndText"
                               Grid.Row="2"
                               Grid.Column="2"
                               Margin="0,10,0,0"
                               Text="00:00"
                               VerticalAlignment="Center" />

                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,20,0,0">
                    <Button x:Name="PlayButton"
                            Content="Play session"
                            MinWidth="120"
                            Height="34"
                            IsEnabled="False"
                            Click="PlayButton_Click" />
                    <Button x:Name="ExportButton"
                            Content="Export selection"
                            MinWidth="140"
                            Height="34"
                            Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="ExportButton_Click" />
                    <Button x:Name="CancelExportButton"
                            Content="Cancel"
                            MinWidth="85"
                            Height="34"
                            Margin="10,0,0,0"
                            Visibility="Collapsed"
                            Click="CancelExportButton_Click" />
                    <Button x:Name="OpenExportButton"
                            Content="Open export"
                            MinWidth="110"
                            Height="34"
                            Margin="10,0,0,0"
                            Visibility="Collapsed"
                            Click="OpenExportButton_Click" />
                </StackPanel>

            </Grid>
        </Grid>

        <ProgressBar x:Name="OperationProgressBar"
                     Grid.Row="2"
                     Height="7"
                     Minimum="0"
                     Maximum="100"
                     Visibility="Collapsed" />
    </Grid>
</Window>
