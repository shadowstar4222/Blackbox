<Window x:Class="Blackbox.App.GameProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Games - Blackbox"
        Height="720"
        Width="1060"
        MinHeight="620"
        MinWidth="880"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Games" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Open taskbar windows and remembered capture profiles"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                <TextBlock x:Name="ActiveCaptureText"
                           Margin="0,7,0,0"
                           Text="Active capture: Automatic selection"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" />
            </StackPanel>
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Content="Refresh"
                    MinWidth="90"
                    Height="32"
                    Click="RefreshButton_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Open application windows" FontSize="16" FontWeight="SemiBold" />
                <ListBox x:Name="RunningApplicationsList"
                         Grid.Row="1"
                         Margin="0,10,0,10"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,3,0,0"
                                           Text="{Binding ExecutableName}"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,3,0,0"
                                           Text="{Binding ActivitySummary}"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                <TextBlock Grid.Row="3"
                                           Margin="0,3,0,0"
                                           Text="{Binding CaptureSummary}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RememberButton"
                            Content="Remember as game"
                            Height="34"
                            Margin="0,0,5,0"
                            IsEnabled="False"
                            Click="RememberButton_Click" />
                    <Button x:Name="AddAliasButton"
                            Grid.Column="1"
                            Content="Add as alias"
                            Height="34"
                            Margin="5,0,0,0"
                            IsEnabled="False"
                            ToolTip="Associate this running executable with the selected remembered game"
                            Click="AddAliasButton_Click" />
                    <Button x:Name="UseForCaptureButton"
                            Grid.Column="2"
                            Content="Use for capture"
                            Height="34"
                            Margin="5,0,0,0"
                            IsEnabled="False"
                            ToolTip="Switch OBS video and game audio to this remembered application"
                            Click="UseForCaptureButton_Click" />
                </Grid>
            </Grid>

            <Separator Grid.Column="1" Margin="11,0" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Remembered games" FontSize="16" FontWeight="SemiBold" />
                <ListBox x:Name="RememberedGamesList"
                         Grid.Row="1"
                         Margin="0,10,0,10"
                         MinHeight="155"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding ExecutablePath}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding ExecutablePath}"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding PreferenceSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Remove"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        Click="RemoveGameButton_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Separator Grid.Row="2" Margin="0,2,0,12" />

                <Grid x:Name="SelectedProfilePanel" Grid.Row="3" IsEnabled="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SelectedGameText" Text="Selected game settings" FontWeight="SemiBold" />
                    <UniformGrid Grid.Row="1" Rows="2" Columns="2" Margin="0,8,0,10">
                        <CheckBox x:Name="AutomaticRecordingCheckBox"
                                  Content="Record automatically"
                                  Margin="0,0,10,7"
                                  Click="ProfilePreferenceCheckBox_Click" />
                        <CheckBox x:Name="CaptureGameAudioCheckBox"
                                  Content="Capture game audio"
                                  Margin="0,0,0,7"
                                  Click="ProfilePreferenceCheckBox_Click" />
                        <CheckBox x:Name="FollowLauncherHandoffCheckBox"
                                  Content="Follow launcher handoffs"
                                  Margin="0,0,10,0"
                                  Click="ProfilePreferenceCheckBox_Click" />
                        <CheckBox x:Name="PreferGpuActivityCheckBox"
                                  Content="Prefer GPU-active window"
                                  Click="ProfilePreferenceCheckBox_Click" />
                    </UniformGrid>
                    <TextBlock Grid.Row="2" Text="Executable aliases" FontWeight="SemiBold" />
                    <Grid Grid.Row="3" Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="AliasesList"
                                 MinHeight="58"
                                 MaxHeight="88"
                                 Background="{StaticResource PanelBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 ItemsSource="{Binding}" />
                        <Button x:Name="RemoveAliasButton"
                                Grid.Column="1"
                                Content="Remove alias"
                                MinWidth="95"
                                Height="32"
                                Margin="10,0,0,0"
                                VerticalAlignment="Top"
                                IsEnabled="False"
                                Click="RemoveAliasButton_Click" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Text="Loading..."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
    </Grid>
</Window>
