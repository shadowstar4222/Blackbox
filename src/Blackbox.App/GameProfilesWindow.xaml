<Window x:Class="Blackbox.App.GameProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Games - Blackbox"
        Height="620"
        Width="920"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Games" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Choose a running game once. Blackbox will remember its executable."
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            </StackPanel>
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Content="Refresh"
                    MinWidth="90"
                    Height="32"
                    Click="RefreshButton_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Running applications" FontSize="16" FontWeight="SemiBold" />
                <ListBox x:Name="RunningApplicationsList"
                         Grid.Row="1"
                         Margin="0,10,0,10"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,3,0,0"
                                           Text="{Binding ExecutableName}"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,3,0,0"
                                           Text="{Binding WindowSize}"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button x:Name="RememberButton"
                        Grid.Row="2"
                        Content="Remember selected game"
                        Height="34"
                        IsEnabled="False"
                        Click="RememberButton_Click" />
            </Grid>

            <Separator Grid.Column="1" Margin="11,0" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Remembered games" FontSize="16" FontWeight="SemiBold" />
                <ListBox x:Name="RememberedGamesList"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{Binding AutomaticRecordingEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          ToolTip="Record automatically while this game is running"
                                          Click="AutomaticRecordingCheckBox_Click" />
                                <StackPanel Grid.Column="1" Margin="9,0,8,0">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding ExecutablePath}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding ExecutablePath}"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="Remove"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        Click="RemoveGameButton_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Text="Loading..."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
    </Grid>
</Window>
