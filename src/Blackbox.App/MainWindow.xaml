<Window x:Class="Blackbox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blackbox" Height="590" Width="720" MinHeight="560" MinWidth="640">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Blackbox" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="Continuous background recorder" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,24,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Status" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText" Grid.Column="1" Text="OBS setup required" TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Text="Backend" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="OBS portable profile adapter" Margin="0,12,0,0" />
            <TextBlock Grid.Row="2" Text="Segment length" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="SegmentLengthText" Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" />
            <TextBlock Grid.Row="3" Text="Location" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="LocationText" Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" TextWrapping="Wrap" />
            <TextBlock Grid.Row="4" Text="Audio tracks" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="Full mix, game, voice chat, raw mic, processed mic" Margin="0,12,0,0" TextWrapping="Wrap" />
            <TextBlock Grid.Row="5" Text="Automatic capture" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="AutomaticCaptureStatusText" Grid.Row="5" Grid.Column="1" Text="Off" Margin="0,12,0,0" TextWrapping="Wrap" />
            <TextBlock Grid.Row="6" Text="Current game" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="CurrentGameText" Grid.Row="6" Grid.Column="1" Text="None detected" Margin="0,12,0,0" TextWrapping="Wrap" />
        </Grid>
        <ProgressBar x:Name="SetupProgressBar"
                     Grid.Row="2"
                     Height="5"
                     Margin="0,0,0,16"
                     Minimum="0"
                     Maximum="100"
                     Visibility="Collapsed" />
        <UniformGrid Grid.Row="3" Rows="4" Columns="3">
            <Button x:Name="ObsSetupButton" Content="Setup OBS" Height="36" Margin="0,0,8,8" Click="ObsSetupButton_Click" />
            <Button x:Name="AudioButton" Content="Apply Audio" Height="36" Margin="0,0,8,8" IsEnabled="False" Click="AudioButton_Click" />
            <Button x:Name="CalibrateButton" Content="Calibrate Mic" Height="36" Margin="0,0,0,8" IsEnabled="False" Click="CalibrateButton_Click" />
            <Button x:Name="RecordingLibraryButton" Content="Recordings" Height="36" Margin="0,0,8,8" Click="RecordingLibraryButton_Click" />
            <Button x:Name="GamesButton" Content="Games" Height="36" Margin="0,0,8,8" Click="GamesButton_Click" />
            <Button x:Name="DiagnosticsButton" Content="Diagnostics" Height="36" Margin="0,0,0,8" Click="DiagnosticsButton_Click" />
            <Button x:Name="OpenRecordingsButton" Content="Open Folder" Height="36" Margin="0,0,8,8" Click="OpenRecordingsButton_Click" />
            <Button x:Name="ProtectButton" Content="Protect 5 Min" Height="36" Margin="0,0,8,8" Click="ProtectButton_Click" />
            <Button x:Name="PruneButton" Content="Apply Quotas" Height="36" Margin="0,0,0,8" Click="PruneButton_Click" />
            <Button x:Name="AutoCaptureButton" Content="Enable Auto" Height="36" Margin="0,0,8,0" IsEnabled="False" Click="AutoCaptureButton_Click" />
            <Button x:Name="StartButton" Content="Start Recording" Height="36" Margin="0,0,8,0" IsEnabled="False" Click="StartButton_Click" />
            <Button x:Name="StopButton" Content="Stop" Height="36" IsEnabled="False" Click="StopButton_Click" />
        </UniformGrid>
    </Grid>
</Window>
