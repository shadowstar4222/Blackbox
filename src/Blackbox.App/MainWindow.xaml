<Window x:Class="Blackbox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Blackbox"
        Icon="Assets/Blackbox.ico"
        Height="720"
        Width="1120"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        StateChanged="MainWindow_StateChanged">
    <Grid x:Name="ShellRoot" Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="88" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="18,16,14,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Width="34"
                           Height="34"
                           VerticalAlignment="Center"
                           Source="Assets/Blackbox.png"
                           SnapsToDevicePixels="True" />
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="16"
                                   FontWeight="Bold"
                                   Text="BLACKBOX" />
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   FontSize="11"
                                   Text="CAPTURE CONSOLE" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1">
                    <TextBlock Margin="22,7,0,7"
                               Style="{StaticResource SecondaryTextStyle}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Text="WORKSPACE" />

                    <RadioButton x:Name="HomeNavButton"
                                 GroupName="Navigation"
                                 IsChecked="True"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="HomeNavButton_Click"
                                 automation:AutomationProperties.Name="Capture dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE80F;" />
                            <TextBlock Text="Capture" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RecordingsNavButton"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="RecordingNavButton_Click"
                                 automation:AutomationProperties.Name="Recordings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE8B2;" />
                            <TextBlock Text="Recordings" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="GamesNavButton"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="GamesNavButton_Click"
                                 automation:AutomationProperties.Name="Games drawer">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE7FC;" />
                            <TextBlock Text="Games" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="MicrophoneNavButton"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="MicrophoneNavButton_Click"
                                 automation:AutomationProperties.Name="Microphone drawer">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE720;" />
                            <TextBlock Text="Microphone" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="DiagnosticsNavButton"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="DiagnosticsNavButton_Click"
                                 automation:AutomationProperties.Name="Diagnostics drawer">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE9D9;" />
                            <TextBlock Text="Diagnostics" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <Separator Margin="18,0,18,10" />
                    <RadioButton x:Name="HelpNavButton"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="HelpNavButton_Click"
                                 automation:AutomationProperties.Name="Help and tutorial">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE897;" />
                            <TextBlock Text="Help" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SettingsNavButton"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavigationButtonStyle}"
                                 Checked="SettingsNavButton_Click"
                                 automation:AutomationProperties.Name="Settings drawer">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="26"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE713;" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </RadioButton>
                    <Grid Margin="22,10,18,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="SidebarStatusDot"
                                 Width="8"
                                 Height="8"
                                 Margin="0,0,9,0"
                                 Fill="{StaticResource WarningBrush}" />
                        <TextBlock x:Name="SidebarStatusText"
                                   Grid.Column="1"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   FontSize="11"
                                   Text="Starting" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="#1A1B1E">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="CurrentViewTitleText"
                                   Style="{StaticResource PageTitleStyle}"
                                   Text="Capture" />
                        <TextBlock x:Name="CurrentViewSubtitleText"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="Continuous recording controls" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusPillStyle}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ObsStatusDot"
                                         Width="8"
                                         Height="8"
                                         Margin="0,0,7,0"
                                         Fill="{StaticResource WarningBrush}" />
                                <TextBlock x:Name="ObsStatusText"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="OBS CHECKING" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusPillStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="19"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="&#xE7FC;" />
                                <TextBlock x:Name="HeaderGameText"
                                           MaxWidth="190"
                                           FontSize="11"
                                           Text="NO GAME"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="24,22,24,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="Capture status" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,7,24,0"
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Text="Checking Blackbox..."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="ProtectButton"
                                    Height="38"
                                    Margin="0,0,8,0"
                                    ToolTip="Protect previous 5 minutes"
                                    Click="ProtectButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,8,0"
                                               FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE72E;" />
                                    <TextBlock Text="Protect 5 min" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="StopButton"
                                    Height="38"
                                    MinWidth="96"
                                    Margin="0,0,8,0"
                                    IsEnabled="False"
                                    ToolTip="Stop the current recording"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="StopButton_Click"
                                    Content="Stop" />
                            <Button x:Name="StartButton"
                                    Height="38"
                                    MinWidth="116"
                                    IsEnabled="False"
                                    ToolTip="Start a manual continuous recording"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="StartButton_Click"
                                    Content="Start recording" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Grid.Row="1"
                                 Margin="0,22,0,0"
                                 Columns="3"
                                 Rows="1">
                        <Border Margin="0,0,8,0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                           FontSize="11"
                                           Text="AUTOMATIC CAPTURE" />
                                <TextBlock x:Name="AutomaticCaptureStatusText"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Off"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Margin="4,0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                           FontSize="11"
                                           Text="CURRENT GAME" />
                                <TextBlock x:Name="CurrentGameText"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="None detected"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                           FontSize="11"
                                           Text="SEGMENT LENGTH" />
                                <TextBlock x:Name="SegmentLengthText"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="-" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2" Margin="0,26,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Recording backend" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="AudioButton"
                                    Margin="0,0,8,0"
                                    IsEnabled="False"
                                    ToolTip="Refresh track routing and the current microphone"
                                    Click="AudioButton_Click"
                                    Content="Apply audio" />
                            <Button x:Name="ObsSetupButton"
                                    MinWidth="112"
                                    ToolTip="Install, configure, or verify Blackbox OBS"
                                    Click="ObsSetupButton_Click"
                                    Content="Setup OBS" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="0,12,0,0"
                            Padding="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                           FontSize="11"
                                           Text="RECORDING LOCATION" />
                                <TextBlock x:Name="LocationText"
                                           Margin="0,7,20,0"
                                           Text="-"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            </StackPanel>
                            <Button x:Name="OpenRecordingsButton"
                                    Grid.Column="1"
                                    Width="38"
                                    Height="36"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Open recording folder"
                                    Click="OpenRecordingsButton_Click"
                                    Content="&#xE8B7;" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4" Margin="0,26,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Quick access" />
                        <UniformGrid Grid.Row="1"
                                     Margin="0,12,0,0"
                                     Columns="5"
                                     Rows="1">
                            <Button x:Name="RecordingLibraryButton"
                                    Margin="0,0,6,0"
                                    ToolTip="Browse, review, tag, and export recordings"
                                    Click="RecordingLibraryButton_Click"
                                    Content="Recordings" />
                            <Button x:Name="GamesButton"
                                    Margin="3,0"
                                    ToolTip="Choose taskbar windows and manage remembered games"
                                    Click="GamesButton_Click"
                                    Content="Games" />
                            <Button x:Name="CalibrateButton"
                                    Margin="3,0"
                                    IsEnabled="False"
                                    ToolTip="Choose microphone routing, exclusions, and calibration"
                                    Click="CalibrateButton_Click"
                                    Content="Microphone" />
                            <Button x:Name="DiagnosticsButton"
                                    Margin="3,0"
                                    ToolTip="Inspect health, storage, logs, and recovery"
                                    Click="DiagnosticsButton_Click"
                                    Content="Diagnostics" />
                            <Button x:Name="AutoCaptureButton"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip="Watch remembered games and record them automatically"
                                    Click="AutoCaptureButton_Click"
                                    Content="Enable auto" />
                        </UniformGrid>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <ProgressBar x:Name="SetupProgressBar"
                         Grid.Row="2"
                         Height="4"
                         Minimum="0"
                         Maximum="100"
                         Visibility="Collapsed" />
        </Grid>

        <Border x:Name="DrawerScrim"
                Grid.ColumnSpan="2"
                Background="#99000000"
                Opacity="0"
                Visibility="Collapsed"
                MouseLeftButtonDown="DrawerScrim_MouseLeftButtonDown" />

        <Border x:Name="DrawerPanel"
                Grid.ColumnSpan="2"
                Width="400"
                HorizontalAlignment="Right"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DrawerTransform" X="400" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="22,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DrawerTitleText"
                                   VerticalAlignment="Center"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Text="Drawer" />
                        <Button x:Name="DrawerCloseButton"
                                Grid.Column="1"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Close drawer"
                                Click="DrawerCloseButton_Click"
                                Content="&#xE711;" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="22">
                        <StackPanel x:Name="GameDrawerContent" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="CURRENT GAME" />
                            <TextBlock x:Name="DrawerGameText"
                                       Margin="0,8,0,22"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="None detected"
                                       TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="AUTOMATIC CAPTURE" />
                            <TextBlock x:Name="DrawerAutomaticStatusText"
                                       Margin="0,8,0,22"
                                       FontSize="15"
                                       Text="Off"
                                       TextWrapping="Wrap" />
                            <Button x:Name="OpenGameManagerButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OpenGameManagerButton_Click"
                                    Content="Manage remembered games" />
                        </StackPanel>

                        <StackPanel x:Name="MicrophoneDrawerContent" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="AUDIO ROUTING" />
                            <TextBlock Margin="0,8,0,22"
                                       FontSize="15"
                                       Text="Full mix, game, voice chat, raw mic, processed mic"
                                       TextWrapping="Wrap" />
                            <Button x:Name="DrawerApplyAudioButton"
                                    Margin="0,0,0,8"
                                    IsEnabled="False"
                                    Click="AudioButton_Click"
                                    Content="Apply audio routing" />
                            <Button x:Name="DrawerCalibrateButton"
                                    IsEnabled="False"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="CalibrateButton_Click"
                                    Content="Open microphone setup" />
                        </StackPanel>

                        <StackPanel x:Name="DiagnosticsDrawerContent" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="SYSTEM STATUS" />
                            <TextBlock x:Name="DrawerSystemStatusText"
                                       Margin="0,8,0,22"
                                       FontSize="15"
                                       Text="Checking Blackbox..."
                                       TextWrapping="Wrap" />
                            <Button x:Name="OpenDiagnosticsWindowButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OpenDiagnosticsWindowButton_Click"
                                    Content="Open diagnostics workspace" />
                        </StackPanel>

                        <StackPanel x:Name="HelpDrawerContent" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="QUICK START" />
                            <TextBlock Margin="0,8,0,18"
                                       FontSize="15"
                                       Text="Run these once, then Blackbox can stay in the notification area and record remembered games automatically."
                                       TextWrapping="Wrap" />

                            <TextBlock FontWeight="SemiBold" Text="1. Prepare OBS" />
                            <TextBlock Margin="0,4,0,8"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Creates the Blackbox scene, recording tracks, and exact-window game capture source."
                                       TextWrapping="Wrap" />
                            <Button Margin="0,0,0,16"
                                    Click="TutorialSetupObsButton_Click"
                                    Content="Check OBS setup" />

                            <TextBlock FontWeight="SemiBold" Text="2. Remember a game" />
                            <TextBlock Margin="0,4,0,8"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Open the game first, refresh the taskbar-window list, select it, and choose Remember as game. Use for capture chooses between remembered games that are open together."
                                       TextWrapping="Wrap" />
                            <Button Margin="0,0,0,16"
                                    Click="TutorialGamesButton_Click"
                                    Content="Open games" />

                            <TextBlock FontWeight="SemiBold" Text="3. Check your microphone" />
                            <TextBlock Margin="0,4,0,8"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Blackbox follows the Windows default microphone. Exclude devices you never want it to use."
                                       TextWrapping="Wrap" />
                            <Button Margin="0,0,0,16"
                                    Click="TutorialMicrophoneButton_Click"
                                    Content="Open microphone setup" />

                            <TextBlock FontWeight="SemiBold" Text="4. Enable automatic capture" />
                            <TextBlock Margin="0,4,0,8"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Enable auto on Capture. Recording starts when a remembered window appears and stops after it closes."
                                       TextWrapping="Wrap" />
                            <Button Margin="0,0,0,22"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="CompleteTutorialButton_Click"
                                    Content="Finish tutorial" />

                            <Separator Margin="0,0,0,20" />
                            <TextBlock Margin="0,0,0,14"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="BUTTON GUIDE" />

                            <TextBlock FontWeight="SemiBold" Text="Start recording / Stop" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Starts or ends a manual continuous session. Segments are joined in the player and during export."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Protect 5 min" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Keeps the previous five minutes from automatic storage cleanup."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Setup OBS / Check OBS" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Builds or verifies the managed OBS profile without changing your personal OBS scenes."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Apply audio" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Refreshes track assignments and routes the current allowed microphone."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Enable auto / Disable auto" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Starts or stops watching for remembered application windows."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Recordings" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Opens session review, timeline markers, tags, and continuous-video export."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Games" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Lists taskbar windows and controls which remembered apps may auto-record."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Microphone" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Controls automatic selection, exclusions, processing, and calibration."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Diagnostics" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Shows system health and provides recovery and support tools."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Settings" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Controls startup, background behavior, recording quality, and storage cleanup."
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,14,0,14"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="REVIEW PLAYER" />
                            <TextBlock FontWeight="SemiBold" Text="Build preview" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Generates cached timeline thumbnails and a waveform without changing the recording."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Play / Pause and -10 / +10" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Controls playback or jumps ten seconds backward and forward across segment boundaries."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Frame and segment arrows" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Steps one frame at a time or jumps to the previous or next recorded segment."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Loop, mute, track, speed, fullscreen" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Changes review playback only; the source recording and exported tracks remain intact."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Quick tags and Add event" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Adds a labeled marker at the current timeline position for later navigation."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Protect selection and Export" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Keeps the selected range from cleanup or exports the chosen range as one continuous file."
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,14,0,14"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="GAME MANAGER" />
                            <TextBlock FontWeight="SemiBold" Text="Refresh applications" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Rebuilds the list from currently visible taskbar windows."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Remember as game" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Adds the selected running window to the automatic-capture allowlist."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Use for capture" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Makes the selected running remembered game the active OBS target, whether recording is running or stopped."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Save profile / Remove profile" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Saves capture preferences for the selected app or removes it from remembered games."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Add alias / Remove alias" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Associates or removes another executable used by the same game or launcher."
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,14,0,14"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="MICROPHONE SETUP" />
                            <TextBlock FontWeight="SemiBold" Text="Apply routing" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Saves automatic selection, exclusions, or the manual microphone and applies it to OBS."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Measure" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Samples room noise, normal speech, or loud speech for processing recommendations."
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Apply recommendations / Record comparison" />
                            <TextBlock Margin="0,3,0,12"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="Saves the measured filters or records before-and-after samples for listening checks."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="SettingsDrawerContent" Visibility="Collapsed">
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="Set up OBS when Blackbox starts" />
                                <ToggleButton x:Name="AutoSetupObsToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource SwitchStyle}"
                                              Click="AutoSetupObsToggle_Click"
                                              automation:AutomationProperties.Name="Set up OBS when Blackbox starts" />
                            </Grid>
                            <Separator Margin="0,0,0,20" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="Start with Windows" />
                                <ToggleButton x:Name="StartWithWindowsToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource SwitchStyle}"
                                              Click="StartWithWindowsToggle_Click"
                                              automation:AutomationProperties.Name="Start Blackbox with Windows" />
                            </Grid>
                            <Separator Margin="0,0,0,20" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="Automatic recording at startup" />
                                <ToggleButton x:Name="WatchGamesToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource SwitchStyle}"
                                              Click="WatchGamesToggle_Click"
                                              automation:AutomationProperties.Name="Enable automatic recording at startup" />
                            </Grid>
                            <Separator Margin="0,0,0,20" />
                            <Grid Margin="0,0,0,26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="Close to notification area" />
                                <ToggleButton x:Name="CloseToTrayToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource SwitchStyle}"
                                              Click="CloseToTrayToggle_Click"
                                              automation:AutomationProperties.Name="Keep Blackbox running in notification area" />
                            </Grid>
                            <Separator Margin="0,0,0,20" />
                            <TextBlock Margin="0,0,0,14"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="RECORDING QUALITY" />
                            <TextBlock Margin="0,0,0,6"
                                       FontSize="13"
                                       Text="Resolution" />
                            <ComboBox x:Name="ResolutionComboBox"
                                      Margin="0,0,0,14"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      automation:AutomationProperties.Name="Recording resolution" />
                            <TextBlock Margin="0,0,0,6"
                                       FontSize="13"
                                       Text="Frame rate" />
                            <ComboBox x:Name="FrameRateComboBox"
                                      Margin="0,0,0,14"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      automation:AutomationProperties.Name="Recording frame rate" />
                            <TextBlock Margin="0,0,0,6"
                                       FontSize="13"
                                       Text="Audio quality" />
                            <ComboBox x:Name="AudioQualityComboBox"
                                      Margin="0,0,0,14"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      automation:AutomationProperties.Name="Recording audio quality" />
                            <Button x:Name="ApplyQualityButton"
                                    Margin="0,0,0,20"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ApplyQualityButton_Click"
                                    Content="Apply recording quality" />
                            <Button x:Name="PruneButton"
                                    Margin="0,0,0,8"
                                    Click="PruneButton_Click"
                                    Content="Apply storage quotas" />
                            <Button Click="OpenRecordingsButton_Click"
                                    Content="Open recording folder" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
