<Window x:Class="Blackbox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blackbox" Height="360" Width="560" MinHeight="320" MinWidth="480">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Blackbox" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="Continuous background recorder" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,24,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Status" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText" Grid.Column="1" Text="Idle" />
            <TextBlock Grid.Row="1" Text="Backend" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="OBS portable profile adapter" Margin="0,12,0,0" />
            <TextBlock Grid.Row="2" Text="Segment length" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="SegmentLengthText" Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" />
            <TextBlock Grid.Row="3" Text="Location" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="LocationText" Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" TextWrapping="Wrap" />
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ProtectButton" Content="Protect 5 Min" Width="120" Height="34" Margin="0,0,8,0" Click="ProtectButton_Click" />
            <Button x:Name="PruneButton" Content="Apply Quotas" Width="120" Height="34" Margin="0,0,8,0" Click="PruneButton_Click" />
            <Button x:Name="StartButton" Content="Start Recording" Width="130" Height="34" Margin="0,0,8,0" Click="StartButton_Click" />
            <Button x:Name="StopButton" Content="Stop" Width="90" Height="34" IsEnabled="False" Click="StopButton_Click" />
        </StackPanel>
    </Grid>
</Window>
